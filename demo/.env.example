# demo/.env.example — Convert Python SDK demo harness configuration
#
# Copy this file to demo/.env (gitignored) and fill in the LIVE block
# to run against real staging. OFFLINE mode requires NO changes here.
#
# USAGE:
#   OFFLINE (default, zero credentials):
#     python demo/run_demo.py
#
#   LIVE (opt-in — uncomment and fill the block below, then):
#     python demo/run_demo.py

# ---------------------------------------------------------------------------
# OFFLINE defaults (active as-is — no credentials required)
# ---------------------------------------------------------------------------

# Fixed visitor id used in OFFLINE mode. Change to test a different bucket.
CONVERT_DEMO_VISITOR_ID=demo-visitor-001

# Revenue amount tracked in the conversion event.
CONVERT_DEMO_REVENUE=29.99

# Set to 1 to bypass (visitor, goal) dedup and re-send the conversion.
# CONVERT_DEMO_FORCE_MULTIPLE=0

# ---------------------------------------------------------------------------
# LIVE block (commented — set CONVERT_SDK_KEY to activate LIVE mode)
#
# The SDK key below is the PUBLIC shared staging project (account_id/project_id).
# Source: ../javascript-sdk/demo/nodejs/app.js:32 (sdkKey: '10035569/10034190')
#         ../php-sdk/demo/laravel/.env.example    (CONVERT_SDK_KEY=10035569/10034190)
#
# Entity keys the demo uses (all match the JS/PHP demos):
#   experience: test-experience-ab-fullstack-1
#     Source: ../javascript-sdk/demo/nodejs/routes/events.js (experienceKey)
#             ../php-sdk/demo/laravel/config/convert.php     (CONVERT_EXPERIENCE_KEY)
#   feature:   test-feature-rollout-1
#     Source: ../javascript-sdk/demo/nodejs/routes/events.js (featureRolloutKey)
#   segment:   test-segment-1
#     Source: ../javascript-sdk/demo/nodejs/routes/events.js (segmentsKey)
#             ../php-sdk/demo/laravel/config/convert.php     (CONVERT_SEGMENT_KEY)
#   goal:      button-primary-click
#     Source: ../php-sdk/demo/laravel/config/convert.php     (goal_key)
#             (JS demo fires no conversion; PHP is the canonical source)
#
# Staging CDN host (SDK builds GET /api/v1/config/{sdkKey} against this):
#   https://cdn-4-staging.convertexperiments.com
# ---------------------------------------------------------------------------

# Uncomment to activate LIVE mode:
# CONVERT_SDK_KEY=10035569/10034190

# Bearer secret — ONLY required for authenticated keys. Leave unset for public keys.
# NEVER commit a real secret value. Set in demo/.env (gitignored) at runtime only.
# CONVERT_AUTH_SECRET=

# Optional LIVE overrides (defaults shown):
# CONVERT_DEMO_HOST=https://cdn-4-staging.convertexperiments.com
# CONVERT_DEMO_TIMEOUT=10
